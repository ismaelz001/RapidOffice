# ─────────────────────────────────────────────────────────────
# Planificación de Oficinas — variables de entorno (PLANTILLA)
# Copia este archivo como `.env.local` (desarrollo) y rellena los valores.
# NUNCA subas .env.local ni secretos reales al repositorio.
# ─────────────────────────────────────────────────────────────

# Entorno: development | staging | production
APP_ENV=development

# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Supabase ofrece DOS URLs (Settings → Database → Connection string):
#
# 1. POOLED (puerto 6543, pgbouncer) → para queries en Vercel/serverless
#    postgresql://postgres.[ref]:[pass]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=
#
# 2. DIRECTA (puerto 5432) → solo para drizzle-kit (migraciones)
#    postgresql://postgres:[pass]@db.[ref].supabase.co:5432/postgres
DATABASE_URL_DIRECT=

# Better Auth — secreto de sesión (genera uno con: openssl rand -base64 32)
BETTER_AUTH_SECRET=
# URL base de la app (sin barra final)
BETTER_AUTH_URL=http://localhost:3000

# URL pública de la app (visible en cliente)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — correo transaccional (Fase posterior)
RESEND_API_KEY=
EMAIL_FROM=

# Almacenamiento de archivos privado (proveedor a confirmar)
STORAGE_BUCKET=
STORAGE_REGION=
